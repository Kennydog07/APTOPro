# APTO Pro — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is listed in .gitignore.
# Add real values via Netlify dashboard:
#   Site Settings → Environment Variables
# ─────────────────────────────────────────────────────────

# Anthropic API Key
# Get yours at: console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Your production domain (used for CORS)
# Example: https://aptopro.netlify.app
ALLOWED_ORIGIN=https://your-site-name.netlify.app

# ── Stripe (Phase 5) ──────────────────────────────────────
# Get these from: dashboard.stripe.com/apikeys
# Use TEST keys during development, LIVE keys in production
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_STARTER_PRICE_ID=your-starter-plan-price-id
STRIPE_PRO_PRICE_ID=your-pro-plan-price-id
STRIPE_AGENCY_PRICE_ID=your-agency-plan-price-id

# ── Supabase (Phase 5) ────────────────────────────────────
# Get these from: supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
